# =============================================================================
# CrewAI Enterprise Control Center — API (FastAPI)
# Governance: Section 3 — Container Strategy
# Multi-stage build: builder → runtime
# =============================================================================

# Stage 1: Python dependencies
FROM python:3.12-slim AS builder
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential libpq-dev gcc && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY packages/shared-types/ packages/shared-types/
COPY packages/crew-runtime/ packages/crew-runtime/
COPY apps/api/ apps/api/
RUN pip install --no-cache-dir -e packages/shared-types && \
    pip install --no-cache-dir -e apps/api

# Stage 2: Runtime
FROM python:3.12-slim AS runtime
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 curl && rm -rf /var/lib/apt/lists/*
RUN groupadd -r crewai && useradd -r -g crewai -d /app -s /sbin/nologin crewai
WORKDIR /app
COPY --from=builder /usr/local/lib/python3.12/site-packages/ /usr/local/lib/python3.12/site-packages/
COPY --from=builder /app/packages/ /app/packages/
COPY --from=builder /app/apps/api/ /app/apps/api/
COPY --from=builder /app/apps/api/.env.example /app/apps/api/.env.example
USER crewai
EXPOSE 8000
HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1
CMD ["uvicorn", "apps.api.src.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "4"]